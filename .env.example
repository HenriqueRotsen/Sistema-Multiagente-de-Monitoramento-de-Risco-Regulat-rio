# Environment variables configuration
# Copy this file to .env and fill with your actual credentials

# ======================
# LLM Configuration
# ======================
# Ollama proxy da disciplina
LLM_PROVIDER=ollama
LLM_BASE_URL=https://ollama.futurelab.dcc.ufmg.br
LLM_API_KEY=your_api_key_here
LLM_API_KEY_HEADER=X-API-Key
LLM_MODEL=llama3.2:3b
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=1.0
LLM_RATE_LIMIT_PER_MINUTE=20

# Alternativa para servidores OpenAI-compatible:
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your_api_key_here
# LLM_MODEL=gpt-4o-mini

# ======================
# Database Configuration
# ======================
DB_URL=sqlite:///regulatory_monitor.db
DB_PATH=./data/regulatory_monitor.db

# ======================
# Embedding Configuration
# ======================
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CHROMA_DB_PATH=./chroma_db

# ======================
# Sources Configuration
# ======================
BCB_NEWS_API_URL=https://www.bcb.gov.br/api/servico/sitebcb/noticias?quantidade=20
CVM_BASE_URL=https://www.cvm.gov.br
CVM_LEGISLATION_URL=https://conteudo.cvm.gov.br/legislacao/index.html?buscado=true&contCategoriasChec=
CVM_MAX_PAGES=2
BCB_TIMEOUT_SECONDS=15
CVM_TIMEOUT_SECONDS=20
SOURCE_RETRY_ATTEMPTS=2
SOURCE_RETRY_BACKOFF_SECONDS=1.0

# ======================
# Logging Configuration
# ======================
LOG_LEVEL=INFO
LOG_FILE=./logs/monitoring.log

# ======================
# Sector Profile
# ======================
SECTOR_FOCUS=fintechs_payments
MONITOR_LANGUAGES=pt-BR
