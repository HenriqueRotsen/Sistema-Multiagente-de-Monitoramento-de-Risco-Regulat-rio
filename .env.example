# Environment variables configuration
# Copy this file to .env and fill with your actual credentials

# ======================
# LLM Configuration
# ======================
# When you have access to powerful API
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4  # or your preferred model
LLM_BASE_URL=https://api.openai.com/v1  # if needed

# ======================
# Database Configuration
# ======================
DB_URL=sqlite:///regulatory_monitor.db
DB_PATH=./data/regulatory_monitor.db

# ======================
# Embedding Configuration
# ======================
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CHROMA_DB_PATH=./chroma_db

# ======================
# Sources Configuration
# ======================
BCB_NEWS_API_URL=https://www.bcb.gov.br/api/servico/sitebcb/noticias?quantidade=20
CVM_BASE_URL=https://www.cvm.gov.br

# ======================
# Logging Configuration
# ======================
LOG_LEVEL=INFO
LOG_FILE=./logs/monitoring.log

# ======================
# Sector Profile
# ======================
SECTOR_FOCUS=fintechs_payments
MONITOR_LANGUAGES=pt-BR
